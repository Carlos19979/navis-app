PORT=8080
APP_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres?sslmode=disable
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://localhost:54321
# Service role key (supabase status → service_role key). Required for account
# deletion; required at boot in production.
SUPABASE_SERVICE_ROLE_KEY=
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
NOVU_API_KEY=
SENTRY_DSN=
# Shared secret RevenueCat sends in the webhook Authorization header.
# Empty rejects all webhook requests; required at boot in production.
REVENUECAT_WEBHOOK_SECRET=
